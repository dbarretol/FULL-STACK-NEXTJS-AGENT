# --- AWS Bedrock ---
# Credenciales para el LLM (Amazon Nova Pro)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# --- Google Gemini (Google AI Studio) ---
# Requiere: strands-agents[gemini]
GOOGLE_API_KEY=your_google_api_key

# --- OpenAI ---
# Requiere: strands-agents[openai]
OPENAI_API_KEY=your_openai_api_key

# --- Anthropic ---
# Requiere: strands-agents[anthropic]
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- LlamaAPI ---
# Requiere: strands-agents[llamaapi]
LLAMA_API_KEY=your_llama_api_key

# --- Sandbox E2B ---
# Sandbox seguro para ejecutar código (https://e2b.dev/)
E2B_API_KEY=your_e2b_api_key
